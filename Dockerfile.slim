# ============================================================
# 轻量 Dockerfile（适配 2G 内存机器）
# 与默认 Dockerfile 的区别：
#   不在容器内构建前端（npm run build 在 2G 机器上易 OOM）。
#   前端需先在【本地电脑】或【CI】构建好，把 web/frontend/dist
#   一起提交/上传，本镜像直接使用现成产物。
#
# 用法：
#   1. 本地：cd web/frontend && npm ci && npm run build
#      （或运行 scripts/build_frontend.sh）
#   2. 确认 web/frontend/dist/index.html 存在
#   3. 服务器：docker compose -f docker-compose.prod.yml build
#      （compose 里 app 的 build 指向本文件，见下方说明）
#
# 让 compose 用本文件：在 docker-compose.prod.yml 的 app 服务下，
#   把  build: .
#   改为：
#     build:
#       context: .
#       dockerfile: Dockerfile.slim
# ============================================================

FROM python:3.12-slim

# 系统依赖（部分 Python 包编译需要，如 argon2-cffi）
RUN apt-get update && \
    apt-get install -y --no-install-recommends build-essential && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Python 依赖（先拷贝 requirements 利用 Docker 缓存）
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# 拷贝项目代码（含本地已构建好的 web/frontend/dist）
COPY . .

# 校验前端产物存在，缺失则构建失败并明确报错（避免起了个没有前端的服务）
RUN test -f /app/web/frontend/dist/index.html || \
    (echo "ERROR: web/frontend/dist/index.html 不存在。请先在本地构建前端：cd web/frontend && npm ci && npm run build" && exit 1)

# 创建持久化目录
RUN mkdir -p /app/data /app/data/voice_cache /app/data/chroma_db

# 非 root 用户运行（安全）
RUN useradd -m -s /bin/bash appuser && chown -R appuser:appuser /app
USER appuser

EXPOSE 7860

HEALTHCHECK --interval=30s --timeout=5s --retries=3 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:7860/api/health')" || exit 1

CMD ["python", "-m", "web.server"]
