# ============================================================
# 环境变量模板 — 复制为 .env 并填写真实值
# ============================================================

# ---- 必填 (启动需要) ----
JWT_SECRET=                    # openssl rand -hex 32

# ---- LLM API ----
# DeepSeek API Key. 不填则需在管理后台 /api/settings/config 中配置
DEEPSEEK_API_KEY=

# ---- 域名和 CORS ----
# 允许的前端域名，逗号分隔（含CDN域名）
ALLOWED_ORIGINS=https://yourdomain.cn,https://cdn.yourdomain.cn

# ---- 邀请码 (管理员注册用) ----
ADMIN_INVITE_CODE=

# ---- 可选 ----
# LOG_LEVEL=INFO
# FFMPEG_PATH=ffmpeg
# HF_TOKEN=                    # HuggingFace token (模型下载加速)

# ---- 邮件验证 (上线必填，否则注册/重置密码不可用) ----
RESEND_API_KEY=              # https://resend.com API Key，必填
# RESEND_FROM_EMAIL=noreply@resend.dev  # 发件人邮箱（有自己域名后换）

# ---- 加密与安全 ----
FERNET_KEY=          # 独立加密密钥，不设则回退 JWT_SECRET（不推荐）
ALLOWED_ORIGINS=https://你的域名.com
