# ============================================================
# 环境变量模板 — 复制为 .env 并填写真实值
#   cp .env.example .env
# ============================================================

# ---- 必填 (启动需要) ----
# JWT 签名密钥，生成: openssl rand -hex 32
JWT_SECRET=

# ---- 存储后端 (必填，未设置服务会 fail-fast 拒绝启动) ----
# postgres 生产推荐；sqlite 用于本地/测试
STORAGE_BACKEND=postgres

# postgres 后端必填，形如 postgresql://用户:密码@host:5432/库名
DATABASE_URL=postgresql://charsim:CHANGE_ME@127.0.0.1:5432/charsim
# 以下三个供 docker-compose 的 postgres 容器初始化使用，需与 DATABASE_URL 一致
POSTGRES_USER=charsim
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=charsim

# sqlite 后端使用（STORAGE_BACKEND=sqlite 时生效），不设默认 data/charsim.db
# DB_PATH=data/charsim.db

# ---- LLM API ----
# DeepSeek API Key. 不填则需在管理后台 /api/settings/config 中配置
DEEPSEEK_API_KEY=

# ---- 域名和 CORS ----
# 允许的前端域名，逗号分隔（双地域同域名，填同一个即可）
ALLOWED_ORIGINS=https://bookecho-shiyu.cn,https://www.bookecho-shiyu.cn

# ---- 邀请码 (管理员/邀请制注册用) ----
ADMIN_INVITE_CODE=

# ---- 邮件验证 (上线必填，否则注册/重置密码不可用) ----
RESEND_API_KEY=                          # https://resend.com API Key
# RESEND_FROM_EMAIL=noreply@resend.dev   # 发件人邮箱（有自己域名后换），默认 noreply@resend.dev

# ---- 加密与安全 ----
FERNET_KEY=                              # 独立加密密钥，不设则回退 JWT_SECRET（不推荐）
INTER_NODE_SECRET=                       # 跨节点 HMAC 密钥（双地域部署必填），生成: openssl rand -hex 32
PEER_NODE_IP=                            # 对端节点公网 IP（双地域部署必填），为空时本机 inter-node 白名单仅 127.0.0.1

# ---- 可选 ----
# DASHSCOPE_API_KEY=                     # 阿里云百炼 API Key（embedding/text-embedding-v4）。
#                                          通常由用户在 Web 设置页自行填写，无需在此统一配置
# FFMPEG_PATH=ffmpeg                     # ffmpeg 可执行文件路径/目录（音视频音轨提取、语音处理）
# BLOCKLIST_PATH=                        # 敏感词黑名单文件路径，不设用内置默认
# DISTILL_USE_COREF=0                    # =1 时蒸馏走共指消解版，默认 0 用原文
# SESSION_IDLE_TTL_SECONDS=3600          # 会话空闲超时秒数，超时后台清理任务清除，默认 3600

# ---- 内容审核阈值 (可选，均有内置默认值) ----
# TRUST_THRESHOLD=0.4                     # 信任阈值，低于此判定需复审
# BLOCK_THRESHOLD=0.7                     # 拦截阈值，高于此直接拦截
# MAX_TOKEN_LENGTH=512                    # 审核预处理单条最大 token 数
# CRISIS_KEYWORDS=                        # 危机词（逗号分隔，覆盖内置默认）
# SEVERE_KEYWORDS=                        # 严重违规词（逗号分隔，覆盖内置默认）
# MODERATE_KEYWORDS=                      # 中度违规词（逗号分隔，覆盖内置默认）
# MILD_KEYWORDS=                          # 轻度违规词（逗号分隔，覆盖内置默认）
